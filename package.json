{
    "name": "only-one",
    "version": "0.0.3",
    "description": "Developer environment setups, AI agent workspace management, and editor configuration syncing.",
    "type": "module",
    "main": "./dist/src/index.js",
    "bin": {
        "only-one": "./dist/src/index.js"
    },
    "files": [
        "dist",
        "scripts",
        "assets"
    ],
    "scripts": {
        "build": "npm run format:check && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && node scripts/postbuild-paths.cjs && node -e \"if (process.platform !== 'win32') require('node:fs').chmodSync('dist/src/index.js', 0o755)\"",
        "dev": "tsx src/index.ts",
        "prepare": "npm run build",
        "test": "npm run format && vitest run",
        "publish:npm": "npm run format && node scripts/publish.js",
        "publish:local": "npm run format && node scripts/publish.js --local",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.ts\""
    },
    "dependencies": {
        "@iarna/toml": "^2.2.5",
        "@inquirer/prompts": "^7.10.1",
        "commander": "^14.0.2",
        "ink": "^7.1.1",
        "js-yaml": "^4.1.0",
        "lodash": "^4.18.1",
        "picocolors": "^1.1.1",
        "react": "^19.2.8"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.17",
        "prettier": "^3.8.3",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vitest": "^4.0.14"
    }
}
